# Set HOST_ADDR to the LAN IP that your RC (Pilot 2) can reach (NOT localhost).
# Example: HOST_ADDR=192.168.1.50
HOST_ADDR=127.0.0.1

# EMQX dashboard login (http://HOST_ADDR:18083)
EMQX_DASH_USER=admin
EMQX_DASH_PASS=public

# MQTT account that Pilot2 will use (configured in the web page)
MQTT_USERNAME=pilot2
MQTT_PASSWORD=pilot2pass

# MySQL credentials for the backend
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=dji_cloud
MYSQL_USER=dji
MYSQL_PASSWORD=djipass

# DJI Cloud API credentials (paste yours here)
DJI_APP_ID=
DJI_APP_KEY=
DJI_LICENSE=
